rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mail2tushar.jain@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isModerator() {
      return isSignedIn() && (
        isAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.size() > 0;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'createdAt', 'degree', 'collegeName', 'experienceYears', 'competitionCount', 'bio', 'skills', 'isDeleted', 'isPaused'])
        && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 100 && data.displayName.size() >= 0
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 2000))
        && (!('gender' in data) || (data.gender is string && data.gender.size() <= 50))
        && (!('darkMode' in data) || (data.darkMode is bool))
        && data.bio is string && data.bio.size() <= 2000
        && data.degree is string && data.degree.size() <= 1000
        && (!('ugDegree' in data) || (data.ugDegree is string && data.ugDegree.size() <= 1000))
        && data.collegeName is string && data.collegeName.size() <= 1000
        && data.experienceYears is number && data.experienceYears >= 0
        && (!('isFresher' in data) || (data.isFresher is bool))
        && (!('companyName' in data) || (data.companyName is string && data.companyName.size() <= 1000))
        && (!('role' in data) || (data.role is string && data.role.size() <= 1000))
        && (!('workExperiences' in data) || (data.workExperiences is list && data.workExperiences.size() <= 5))
        && (!('isPaused' in data) || (data.isPaused is bool))
        && (!('isDeleted' in data) || (data.isDeleted is bool))
        && (!('isBlocked' in data) || (data.isBlocked is bool))
        && (!('dismissedAnnouncements' in data) || (data.dismissedAnnouncements is list))
        && (!('lastActiveAt' in data) || (data.lastActiveAt is timestamp))
        && data.competitionCount is number && data.competitionCount >= 0
        && data.skills is list && data.skills.size() <= 50
        && data.createdAt == request.time;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'receiverId', 'createdAt', 'isRead'])
        && data.senderId == request.auth.uid
        && data.receiverId is string && isValidId(data.receiverId)
        && data.text is string && data.text.size() > 0 && data.text.size() <= 2000
        && data.isRead is bool
        && data.createdAt == request.time;
    }

    function isValidEndorsement(data) {
      return data.keys().hasAll(['endorserId', 'endorseeId', 'skill', 'createdAt'])
        && data.endorserId == request.auth.uid
        && data.endorseeId is string && isValidId(data.endorseeId)
        && data.skill is string && data.skill.size() > 0 && data.skill.size() <= 50
        && data.createdAt == request.time;
    }

    // Collection: Users
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn(); // Users need to find each other to partner up.
      
      allow create: if isOwner(userId) && isValidUserProfile(incoming()) && isValidId(userId);
      
      allow update: if (isOwner(userId) || isModerator())
        && isValidId(userId)
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && (
          (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'isDeleted', 'isPaused', 'isBlocked', 'displayName', 'photoURL', 'gender', 'darkMode', 'skills', 'degree', 'ugDegree', 'collegeName', 'experienceYears', 'isFresher', 'companyName', 'workExperiences', 'competitionCount', 'bio', 'uid', 'email', 'lastActiveAt', 'dismissedAnnouncements'])) ||
          (isModerator() && incoming().diff(existing()).affectedKeys().hasOnly(['isPaused', 'isBlocked', 'displayName', 'photoURL', 'gender', 'darkMode', 'skills', 'degree', 'ugDegree', 'collegeName', 'experienceYears', 'isFresher', 'companyName', 'workExperiences', 'competitionCount', 'bio', 'uid', 'email', 'lastActiveAt', 'dismissedAnnouncements'])) ||
          (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'gender', 'darkMode', 'skills', 'degree', 'ugDegree', 'collegeName', 'experienceYears', 'isFresher', 'companyName', 'workExperiences', 'competitionCount', 'bio', 'uid', 'email', 'isPaused', 'isDeleted', 'lastActiveAt', 'dismissedAnnouncements']))
        );
    }

    // Collection: Chats and Messages
    match /chats/{chatId} {
      allow get: if isSignedIn() && isValidId(chatId);
      
      match /messages/{messageId} {
        allow list: if isSignedIn() 
          && isValidId(chatId)
          && (chatId.matches('.*' + request.auth.uid + '.*') || isAdmin());
          
        allow get: if isSignedIn() 
          && isValidId(chatId)
          && isValidId(messageId)
          && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
        
        allow create: if isSignedIn() 
          && isValidId(chatId)
          && isValidId(messageId)
          && isValidChatMessage(incoming());

        allow update: if isSignedIn()
          && isValidId(chatId)
          && isValidId(messageId)
          && existing().receiverId == request.auth.uid
          && incoming().diff(existing()).affectedKeys().hasOnly(['isRead'])
          && incoming().isRead == true;
          
        allow delete: if isSignedIn() && isValidId(chatId) && (chatId.matches('.*' + request.auth.uid + '.*') || isAdmin());
      }
    }

    match /{path=**}/messages/{messageId} {
      allow list: if isSignedIn() && (resource.data.receiverId == request.auth.uid || resource.data.senderId == request.auth.uid || isAdmin());
    }

    // Collection: Endorsements
    match /endorsements/{endorsementId} {
      allow get: if isSignedIn() && isValidId(endorsementId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(endorsementId) && incoming().endorserId == request.auth.uid && incoming().keys().hasAll(['endorserId', 'endorseeId', 'skill', 'createdAt']) && incoming().size() == 4;
      allow delete: if isSignedIn() && isValidId(endorsementId) && resource.data.endorserId == request.auth.uid;
    }

    // Collection: Message Requests
    match /messageRequests/{requestId} {
      allow read: if isSignedIn() && isValidId(requestId) && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(requestId) 
        && incoming().senderId == request.auth.uid 
        && incoming().keys().hasAll(['senderId', 'receiverId', 'status', 'createdAt'])
        && incoming().size() == 4
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(requestId)
        && (
           // receiver can accept or reject
           (existing().receiverId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && (incoming().status == 'accepted' || incoming().status == 'rejected'))
        );
      allow delete: if isSignedIn() && isValidId(requestId) && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
    }

    // Collection: Reports
    match /reports/{reportId} {
      allow read: if isModerator();
      allow list: if isModerator();
      allow create: if isSignedIn() && isValidId(reportId)
        && incoming().reporterId == request.auth.uid
        && incoming().keys().hasAll(['reporterId', 'reportedId', 'reason', 'status', 'createdAt'])
        && incoming().size() == 5
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
      allow update: if isModerator() && isValidId(reportId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
        && (incoming().status == 'reviewed' || incoming().status == 'pending');
      allow delete: if isAdmin() && isValidId(reportId);
    }

    // Collection: Announcements
    match /announcements/{announcementId} {
      allow list: if true; // Everyone can read active announcements (handled by query)
      allow get: if true;
      allow create: if (isModerator()) && isValidId(announcementId) && incoming().senderId == request.auth.uid;
      allow update: if (isModerator()) && isValidId(announcementId);
      allow delete: if isAdmin() && isValidId(announcementId);
    }

    // Collection: Settings
    match /settings/{settingId} {
      allow list: if true; // Everyone needs setting
      allow get: if true;   // Everyone needs setting
      allow write: if isModerator() && isValidId(settingId);
    }

    // Collection: Typing
    match /typing/{chatId} {
      allow read: if isSignedIn() && (chatId.matches('.*' + request.auth.uid + '.*') || isAdmin());
      allow write: if isSignedIn() && (chatId.matches('.*' + request.auth.uid + '.*') || isAdmin());
    }

    // Collection: Support Tickets
    match /supportTickets/{ticketId} {
      allow read: if isModerator() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isModerator() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(ticketId) && incoming().userId == request.auth.uid;
      allow update: if isModerator() && isValidId(ticketId);
      allow delete: if isModerator() && isValidId(ticketId);
    }
  }
}
