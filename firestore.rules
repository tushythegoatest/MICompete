rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mail2tushar.jain@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isModerator() {
      return isSignedIn() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator')
      );
    }

    function isValidId(id) {
      return id is string 
        && id.size() <= 128 
        && id.size() > 0 
        && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isEmailVerified() {
      // Lenient for Google users as requested by common issues with mobile/iframe providers
      return request.auth.token.email_verified == true || 
             (request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUserProfile(data) {
      let requiredFields = ['uid', 'displayName', 'email', 'createdAt', 'degree', 'collegeName', 'experienceYears', 'competitionCount', 'bio', 'skills', 'isDeleted', 'isPaused'];
      return data.keys().hasAll(requiredFields)
        && data.uid == request.auth.uid
        && isEmailVerified()
        && data.displayName is string && data.displayName.size() <= 100
        && data.bio is string && data.bio.size() <= 2500
        && data.email is string && data.email.size() <= 200
        && data.degree is string && data.degree.size() <= 1000
        && data.collegeName is string && data.collegeName.size() <= 1000
        && data.experienceYears is number
        && data.competitionCount is number
        && data.skills is list && data.skills.size() <= 100
        && data.createdAt == request.time;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'receiverId', 'createdAt', 'isRead'])
        && data.keys().size() == 5
        && data.senderId == request.auth.uid
        && isEmailVerified()
        && data.receiverId is string && isValidId(data.receiverId)
        && data.text is string && data.text.size() > 0 && data.text.size() <= 2000
        && data.isRead is bool
        && data.createdAt == request.time;
    }

    function isValidEndorsement(data) {
      return data.keys().hasAll(['endorserId', 'endorseeId', 'skill', 'createdAt'])
        && data.keys().size() == 4
        && data.endorserId == request.auth.uid
        && isEmailVerified()
        && data.endorseeId is string && isValidId(data.endorseeId)
        && data.skill is string && data.skill.size() > 0 && data.skill.size() <= 50
        && data.createdAt == request.time;
    }

    // Collection: Users
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn();
      
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming());
      
      allow update: if isValidId(userId) && (
        isAdmin() || 
        isModerator() || 
        (isOwner(userId) && 
         incoming().uid == existing().uid && 
         incoming().email == existing().email &&
         incoming().diff(existing()).affectedKeys().hasOnly([
           'jobRole', 'displayName', 'photoURL', 'gender', 'darkMode', 
           'skills', 'degree', 'ugDegree', 'collegeName', 'experienceYears', 
           'isFresher', 'companyName', 'workExperiences', 'competitionCount', 
           'bio', 'uid', 'email', 'isPaused', 'isDeleted', 'lastActiveAt', 
           'dismissedAnnouncements', 'dismissedCampaigns', 'createdAt'
         ])
        )
      );
    }

    // Collection: Chats and Messages
    match /chats/{chatId} {
      allow get: if isSignedIn() && isValidId(chatId);
      
      match /messages/{messageId} {
        allow list: if isSignedIn() 
          && isValidId(chatId)
          && (chatId.matches('.*' + request.auth.uid + '.*') || isAdmin());
          
        allow get: if isSignedIn() 
          && isValidId(chatId)
          && isValidId(messageId)
          && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
        
        allow create: if isSignedIn() 
          && isValidId(chatId)
          && isValidId(messageId)
          && isValidChatMessage(incoming());

        allow update: if isSignedIn()
          && isValidId(chatId)
          && isValidId(messageId)
          && existing().receiverId == request.auth.uid
          && incoming().diff(existing()).affectedKeys().hasOnly(['isRead'])
          && incoming().isRead == true;
          
        allow delete: if isSignedIn() && isValidId(chatId) && (chatId.matches('.*' + request.auth.uid + '.*') || isAdmin());
      }
    }

    match /{path=**}/messages/{messageId} {
      allow list: if isSignedIn() && (resource.data.receiverId == request.auth.uid || resource.data.senderId == request.auth.uid || isAdmin());
    }

    // Collection: Endorsements
    match /endorsements/{endorsementId} {
      allow get: if isSignedIn() && isValidId(endorsementId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(endorsementId) && incoming().endorserId == request.auth.uid && incoming().keys().hasAll(['endorserId', 'endorseeId', 'skill', 'createdAt']) && incoming().size() == 4;
      allow delete: if isSignedIn() && isValidId(endorsementId) && resource.data.endorserId == request.auth.uid;
    }

    // Collection: Message Requests
    match /messageRequests/{requestId} {
      allow read: if isSignedIn() && isValidId(requestId) && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(requestId) && isEmailVerified()
        && incoming().senderId == request.auth.uid 
        && incoming().keys().hasAll(['senderId', 'receiverId', 'status', 'createdAt'])
        && incoming().size() == 4
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(requestId) && isEmailVerified()
        && (
           // receiver can accept or reject
           (existing().receiverId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && (incoming().status == 'accepted' || incoming().status == 'rejected'))
        );
      allow delete: if isSignedIn() && isValidId(requestId) && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
    }

    // Collection: Reports
    match /reports/{reportId} {
      allow read: if isModerator();
      allow list: if isModerator();
      allow create: if isSignedIn() && isValidId(reportId) && isEmailVerified()
        && incoming().reporterId == request.auth.uid
        && incoming().keys().hasAll(['reporterId', 'reportedId', 'reason', 'status', 'createdAt'])
        && incoming().size() == 5
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
      allow update: if isModerator() && isValidId(reportId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
        && (incoming().status == 'reviewed' || incoming().status == 'pending');
      allow delete: if isAdmin() && isValidId(reportId);
    }

    // Collection: Announcements
    match /announcements/{announcementId} {
      allow list: if true; // Everyone can read active announcements (handled by query)
      allow get: if true;
      allow create: if (isModerator()) && isValidId(announcementId) && incoming().senderId == request.auth.uid;
      allow update: if (isModerator()) && isValidId(announcementId);
      allow delete: if isAdmin() && isValidId(announcementId);
    }

    // Collection: Settings
    match /settings/{settingId} {
      allow list: if true; // Everyone needs setting
      allow get: if true;   // Everyone needs setting
      allow write: if isModerator() && isValidId(settingId);
    }

    // Collection: Typing
    match /typing/{chatId} {
      allow read: if isSignedIn() && (chatId.matches('.*' + request.auth.uid + '.*') || isAdmin());
      allow write: if isSignedIn() && (chatId.matches('.*' + request.auth.uid + '.*') || isAdmin());
    }

    // Collection: Support Tickets
    match /supportTickets/{ticketId} {
      allow read: if isModerator() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isModerator() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(ticketId) && isEmailVerified() && incoming().userId == request.auth.uid;
      allow update: if isModerator() && isValidId(ticketId);
      allow delete: if isModerator() && isValidId(ticketId);
    }

    // Collection: Audit Logs
    match /auditLogs/{logId} {
      allow read: if isModerator();
      allow list: if isModerator();
      allow create: if isModerator() && isValidId(logId) && incoming().adminId == request.auth.uid;
    }

    // Collection: Campaigns
    match /campaigns/{campaignId} {
      allow read: if isModerator() || (isSignedIn() && request.auth.uid in resource.data.targetUserIds);
      allow list: if isModerator() || (isSignedIn() && request.auth.uid in resource.data.targetUserIds);
      allow create: if isModerator() && isValidId(campaignId) && incoming().creatorId == request.auth.uid;
      allow update: if (isModerator() && isValidId(campaignId)) || 
        (isSignedIn() && isValidId(campaignId) && request.auth.uid in existing().targetUserIds && incoming().diff(existing()).affectedKeys().hasOnly(['readCount']) && incoming().readCount is number);
      allow delete: if isAdmin() && isValidId(campaignId);
    }
  }
}
